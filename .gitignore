*.egg
.venv/
venv/
env/

# ── macOS ─────────────────────────────────────────────
.DS_Store
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# ── IDE / Editor ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Data backups ──────────────────────────────────────
backup_*.json

# ── Internal documents (not for publication) ──────────
